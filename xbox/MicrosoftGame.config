<?xml version="1.0" encoding="utf-8"?>
<!--
  MicrosoftGame.config — Xbox GDK package manifest for Newtonia
  =============================================================

  BEFORE SHIPPING: fill in every value marked with TODO below.
  All values must exactly match what is registered in Partner Center.

  Where to find each value
  ------------------------
  Identity/@Name        : Partner Center → Your product → Product identity → Package/Identity/Name
  Identity/@Publisher   : Partner Center → Your product → Product identity → Package/Identity/Publisher
  StoreId               : Partner Center → Your product → Product identity → Store ID  (12 chars)
  ShellVisuals/@PublisherDisplayName : Partner Center → Publisher display name

  Image assets
  ------------
  All paths are relative to the layout root (xbox_output/ in the workflow).
  Minimum required sizes:
    StoreLogo.png         : 50 × 50
    Logo480x480.png       : 480 × 480  (Square480x480Logo — tile)
    Logo150x150.png       : 150 × 150  (Square150x150Logo — small tile)
    SplashScreen.png      : 1920 × 1080
  Place these files in xbox/Assets/ and they will be copied into the layout
  by the deploy workflow.
-->
<Game configVersion="1">

  <!-- TODO: replace with values from Partner Center → Product identity -->
  <Identity Name="YourPublisher.Newtonia"
            Publisher="CN=YourPublisher"
            Version="1.0.0.0"/>

  <ExecutableList>
    <!-- TargetDeviceFamily="XboxOne" covers both Xbox One and Xbox Series X|S
         in backward-compatible mode.  Change to "Scarlett" to target Series
         X|S exclusively (enables higher-res assets, faster load, etc.). -->
    <Executable Name="newtonia.exe"
                TargetDeviceFamily="XboxOne"
                Id="Game"/>
  </ExecutableList>

  <DefaultDisplayName>Newtonia</DefaultDisplayName>

  <!-- TODO: your studio / publisher display name -->
  <PublisherDisplayName>TODO: Your Publisher Name</PublisherDisplayName>

  <Description>Top-down 2D space shooter. Destroy asteroids, fight enemies, survive.</Description>

  <!-- TODO: 12-character Store ID from Partner Center → Product identity -->
  <StoreId>XXXXXXXXXXXX</StoreId>

  <Resources>
    <Resource Language="en-us"/>
  </Resources>

  <ShellVisuals DefaultDisplayName="Newtonia"
                PublisherDisplayName="TODO: Your Publisher Name"
                StoreLogo="Assets\StoreLogo.png"
                Square480x480Logo="Assets\Logo480x480.png"
                Square150x150Logo="Assets\Logo150x150.png"
                SplashScreenImage="Assets\SplashScreen.png"
                ForegroundText="light"
                BackgroundColor="#000000"/>

</Game>
